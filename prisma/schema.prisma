// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TestMessage {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
}

model Project {
  id             String   @id @default(cuid())
  name           String
  projectRef     String   @unique
  projectUrl     String
  serviceRoleKey String
  databaseUrl    String
  environment    String   @default("production")
  createdAt      DateTime @default(now())
}

model Developer {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  reason     String
  status     String     @default("pending")
  lastSeenAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  tasks      Task[]
  clients    Client[]
  logs       AuditLog[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo") // Has states: 'todo', 'in_progress', 'done'
  developerId String
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
}

model Client {
  id             String     @id @default(cuid())
  clientRef      String     @unique
  name           String
  email          String
  company        String?
  companyType    String?
  authorizedName String?
  phone          String?
  address        String?
  developerId    String?
  developer      Developer? @relation(fields: [developerId], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now()) @updatedAt
}

model AuditLog {
  id          String    @id @default(cuid())
  action      String
  details     String?
  developerId String
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model ChatMessage {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  senderName String
  receiverId String?
  channel    String   @default("all")
  createdAt  DateTime @default(now())
}

model CallLog {
  id           String    @id @default(cuid())
  roomId       String
  callerId     String
  callerName   String
  receiverId   String?
  receiverName String?
  status       String    @default("initiated") // initiated | accepted | rejected | missed | ended
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  durationSecs Int?
}
